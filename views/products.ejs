<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.productsHub.eyebrow %></p>
    <h1><%= t.productsHub.title %></h1>
    <p class="lead"><%= t.productsHub.lead %></p>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="product-card-grid product-hub-grid reveal-grid">
      <a href="<%= withLang('/termekek/horeca') %>" class="product-card panel product-card-link product-hub-card" data-stagger>
        <div class="product-image-slot">
          <img
            src="/images/optimized/products/kebab-nyars-640.jpg?v=<%= assetVersion || 'local' %>"
            srcset="/images/optimized/products/kebab-nyars-640.jpg?v=<%= assetVersion || 'local' %> 640w, /images/optimized/products/kebab-nyars-960.jpg?v=<%= assetVersion || 'local' %> 960w"
            sizes="(max-width: 768px) calc(100vw - 2rem), 510px"
            alt="<%= t.productsHub.horecaTitle %>"
            class="product-slot-image"
            width="640"
            height="276"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="eyebrow"><%= t.nav.wholesale %></p>
        <h2><%= t.productsHub.horecaTitle %></h2>
        <p><%= t.productsHub.horecaText %></p>
        <span class="text-link"><%= t.productsHub.open %></span>
      </a>

      <a href="<%= withLang('/termekek/kiskereskedelem') %>" class="product-card panel product-card-link product-hub-card" data-stagger>
        <div class="product-image-slot">
          <img
            src="/images/optimized/products/kiskereskedelem-640.jpg?v=<%= assetVersion || 'local' %>"
            srcset="/images/optimized/products/kiskereskedelem-640.jpg?v=<%= assetVersion || 'local' %> 640w, /images/optimized/products/kiskereskedelem-960.jpg?v=<%= assetVersion || 'local' %> 960w"
            sizes="(max-width: 768px) calc(100vw - 2rem), 510px"
            alt="<%= t.productsHub.retailTitle %>"
            class="product-slot-image"
            width="640"
            height="276"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="eyebrow"><%= t.nav.retail %></p>
        <h2><%= t.productsHub.retailTitle %></h2>
        <p><%= t.productsHub.retailText %></p>
        <span class="text-link"><%= t.productsHub.open %></span>
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
