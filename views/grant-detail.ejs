<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow">Pályázat részletei</p>
    <h1><%= grant.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide">
      <img src="<%= grant.image %>" alt="<%= grant.title %> pályázat" class="grant-image" />

      <p><strong>Kedvezményezett neve:</strong> <%= grant.beneficiary %></p>
      <p><strong>Pályázati felhívás neve, kódszáma:</strong> <%= grant.call %></p>
      <p><strong>Projekt címe, azonosító száma:</strong> <%= grant.project %></p>
      <p><strong>Szerződött támogatás összege:</strong> <%= grant.amount %></p>
      <p><strong>Támogatás mértéke (%-ban):</strong> <%= grant.supportRate %></p>

      <h3>Projekt tartalmának rövid bemutatása</h3>
      <% grant.summary.forEach((line) => { %>
      <p><%= line %></p>
      <% }) %>

      <p><strong>Projekt tervezett befejezési dátuma:</strong> <%= grant.endDate %></p>
    </article>
  </div>
</section>

<%- include('partials/footer') %>
