<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.grants.detailsEyebrow %></p>
    <h1><%= grant.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide">
      <img src="<%= grant.image %>" alt="<%= grant.title %>" class="grant-image" />
      <p><strong><%= t.grants.beneficiary %>:</strong> <%= grant.beneficiary %></p>
      <p><strong><%= t.grants.call %>:</strong> <%= grant.call %></p>
      <p><strong><%= t.grants.project %>:</strong> <%= grant.project %></p>
      <p><strong><%= t.grants.amount %>:</strong> <%= grant.amount %></p>
      <p><strong><%= t.grants.supportRate %>:</strong> <%= grant.supportRate %></p>

      <h3><%= t.grants.summary %></h3>
      <% grant.summary.forEach((line) => { %>
      <p><%= line %></p>
      <% }) %>

      <p><strong><%= t.grants.endDate %>:</strong> <%= grant.endDate %></p>
    </article>
  </div>
</section>

<%- include('partials/footer') %>

