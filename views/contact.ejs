<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.contact.eyebrow %></p>
    <h1><%= t.contact.title %></h1>
    <p class="lead"><%= t.contact.lead %></p>
  </div>
</section>

<section class="section section-animate">
  <div class="container contact-grid">
    <aside class="panel">
      <h2><%= t.contact.details %></h2>
      <p><strong><%= t.contact.company %>:</strong> <%= company?.name || 'Halasi Kebpro Kft.' %></p>
      <p><strong><%= t.contact.address %>:</strong> <%= company?.address || '' %></p>
      <% if (company?.phone) { %>
      <p><strong><%= t.contact.phone1 %>:</strong> <a href="tel:<%= company.phone.replace(/\s+/g, '') %>"><%= company.phone %></a></p>
      <% } %>
      <% if (company?.phone2) { %>
      <p><strong><%= t.contact.phone2 %>:</strong> <a href="tel:<%= company.phone2.replace(/\s+/g, '') %>"><%= company.phone2 %></a></p>
      <% } %>
      <% if (company?.fax) { %>
      <p><strong><%= t.contact.fax %>:</strong> <%= company.fax %></p>
      <% } %>
      <% if (company?.email) { %>
      <p><strong><%= t.contact.email %>:</strong> <a href="mailto:<%= company.email %>"><%= company.email %></a></p>
      <% } %>
      <p><strong><%= t.contact.opening %>:</strong> <%= t.contact.openingHours %></p>
    </aside>

    <div class="panel">
      <h2><%= t.contact.quickTitle %></h2>
      <p><%= t.contact.quickText %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.nav.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.nav.order %></a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

