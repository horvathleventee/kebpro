<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.quality.eyebrow %></p>
    <h1><%= t.quality.title %></h1>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.quality.timelineTitle %></h2>
      <p><%= t.quality.timelineLead %></p>
    </div>

    <% const timelineCopy = {
      hu: {
        introKicker: 'Gyártási lánc',
        introTitle: 'Folyamatos ellenőrzés a beszállítástól a késztermékig',
        introText: 'A kiemelt lépések között végig megmarad a minőségbiztosítási kontroll, a hűtőlánc és a nyomonkövethetőség. Az idővonal aktív elemei görgetéskor külön hangsúlyt kapnak.',
        checks: ['Hőmérséklet-ellenőrzés', 'Nyomonkövetés', 'Hűtőlánc biztosítva'],
        icons: ['Be', 'OK', 'Hű', 'Üz', 'Fű', 'Pih', 'Ny', 'Csom', 'Süt'],
        titles: ['Beszállítás', 'Minőségi ellenőrzés', 'Hűtőtárolás', 'Gyártócsarnok', 'Fűszerezés', 'Pihentetés', 'Nyársra építés', 'Formázás és csomagolás', 'Készre sütés'],
        tags: ['Alapanyag', 'Kontrollpont', 'Hűtőlánc', 'Előkészítés', 'Ízprofil', 'Folyamat', 'Összeállítás', 'Késztermék', 'Sütés'],
        stepLabel: 'Lépés'
      },
      en: {
        introKicker: 'Production chain',
        introTitle: 'Continuous control from intake to finished product',
        introText: 'Quality assurance checkpoints, cold-chain control and traceability remain visible throughout the highlighted steps. Active timeline elements gain extra emphasis while scrolling.',
        checks: ['Temperature control', 'Traceability', 'Cold chain secured'],
        icons: ['In', 'QC', 'Cold', 'Prod', 'Sea', 'Rest', 'Skw', 'Pack', 'Grill'],
        titles: ['Inbound supply', 'Quality control', 'Cold storage', 'Production hall', 'Seasoning', 'Resting', 'Skewer assembly', 'Shaping and packing', 'Grilling'],
        tags: ['Raw material', 'Checkpoint', 'Cold chain', 'Preparation', 'Flavor profile', 'Process', 'Assembly', 'Finished product', 'Grilling'],
        stepLabel: 'Step'
      },
      de: {
        introKicker: 'Produktionskette',
        introTitle: 'Kontinuierliche Kontrolle vom Wareneingang bis zum Fertigprodukt',
        introText: 'Zwischen den hervorgehobenen Schritten bleiben Qualitätskontrolle, Kühlkette und Rückverfolgbarkeit dauerhaft im Fokus. Aktive Elemente der Zeitlinie werden beim Scrollen zusätzlich betont.',
        checks: ['Temperaturkontrolle', 'Rückverfolgbarkeit', 'Kühlkette gesichert'],
        icons: ['WE', 'QK', 'Kühl', 'Prod', 'Würz', 'Ruh', 'Sp', 'Pack', 'Gar'],
        titles: ['Wareneingang', 'Qualitätskontrolle', 'Kühllagerung', 'Produktionshalle', 'Würzen', 'Ruhephase', 'Spießaufbau', 'Formung und Verpackung', 'Fertiggaren'],
        tags: ['Rohstoff', 'Kontrollpunkt', 'Kühlkette', 'Vorbereitung', 'Geschmacksprofil', 'Prozess', 'Montage', 'Fertigprodukt', 'Garen'],
        stepLabel: 'Schritt'
      }
    }; %>
    <% const timeline = timelineCopy[lang] || timelineCopy.hu; %>

    <div class="quality-timeline-grid">
      <div class="timeline-intro panel">
        <span class="timeline-intro-kicker"><%= timeline.introKicker %></span>
        <h3><%= timeline.introTitle %></h3>
        <p><%= timeline.introText %></p>
        <div class="timeline-checks">
          <% timeline.checks.forEach((check) => { %>
          <span class="timeline-check"><%= check %></span>
          <% }) %>
        </div>
        <figure class="timeline-quality-photo">
          <img src="/images/company/minoseg.png" alt="<%= t.quality.photoAlt || t.quality.timelineTitle %>" loading="lazy" decoding="async" />
        </figure>
      </div>

      <div class="timeline timeline-advanced">
        <% t.quality.sections.process.steps.forEach((step, index) => { %>
        <article class="timeline-item timeline-step-card" data-stagger>
          <div class="timeline-marker">
            <span class="timeline-marker-number">0<%= index + 1 %></span>
            <span class="timeline-marker-icon"><%= timeline.icons[index] || '•' %></span>
          </div>
          <div class="timeline-content panel">
            <div class="timeline-step-topline">
              <span class="timeline-step-tag"><%= timeline.tags[index] || timeline.stepLabel %></span>
              <strong><%= timeline.titles[index] || `${timeline.stepLabel} ${index + 1}` %></strong>
            </div>
            <h3><%= step %></h3>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide legal-content quality-article">
      <% Object.entries(t.quality.sections).forEach(([key, section]) => { %>
      <section class="quality-block quality-block-<%= key %>">
        <div class="quality-block-head">
          <span class="quality-block-chip"><%= section.title %></span>
          <h2><%= section.title %></h2>
        </div>

        <% if (section.paragraphs) { %>
        <div class="quality-copy-grid">
          <% section.paragraphs.forEach((paragraph) => { %>
          <p><%= paragraph %></p>
          <% }) %>
        </div>
        <% } %>

        <% if (section.steps) { %>
        <ol class="quality-steps-list">
          <% section.steps.forEach((step) => { %>
          <li><%= step %></li>
          <% }) %>
        </ol>
        <% } %>
      </section>
      <% }) %>
    </article>
  </div>
</section>

<%- include('partials/footer') %>
