<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.quality.eyebrow %></p>
    <h1><%= t.quality.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide legal-content">
      <% Object.values(t.quality.sections).forEach((section) => { %>
      <h2><%= section.title %></h2>
      <% if (section.paragraphs) { %>
      <% section.paragraphs.forEach((paragraph) => { %>
      <p><%= paragraph %></p>
      <% }) %>
      <% } %>
      <% if (section.steps) { %>
      <ol>
        <% section.steps.forEach((step) => { %>
        <li><%= step %></li>
        <% }) %>
      </ol>
      <% } %>
      <% }) %>
    </article>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.quality.timelineTitle %></h2>
      <p><%= t.quality.timelineLead %></p>
    </div>
    <div class="timeline">
      <% t.quality.sections.process.steps.forEach((step, index) => { %>
      <article class="timeline-item" data-stagger>
        <div class="timeline-marker">0<%= index + 1 %></div>
        <div class="timeline-content panel">
          <h3><%= step %></h3>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
