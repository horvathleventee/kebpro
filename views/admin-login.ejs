<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin belépés | Halasi Kebpro Kft.</title>
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Manrope', sans-serif;
      min-height: 100dvh;
      display: grid;
      place-items: center;
      background: #0f0f0f;
      background-image:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(218, 138, 29, 0.18) 0%, transparent 70%);
      padding: 1.5rem;
    }

    .login-card {
      width: 100%;
      max-width: 400px;
      background: #1a1a1a;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 1.25rem;
      padding: 2.5rem 2rem;
      box-shadow: 0 24px 64px rgba(0,0,0,0.6);
    }

    .login-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .login-logo img {
      height: 40px;
      width: auto;
    }

    .login-logo span {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      opacity: 0.85;
    }

    h1 {
      font-size: 1.4rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 0.4rem;
    }

    .subtitle {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.45);
      margin-bottom: 2rem;
    }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.4rem;
    }

    input {
      display: block;
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: 0.625rem;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      color: #fff;
      font-family: inherit;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s, background 0.2s;
      margin-bottom: 1.25rem;
    }

    input:focus {
      border-color: #da8a1d;
      background: rgba(218,138,29,0.07);
    }

    input::placeholder { color: rgba(255,255,255,0.25); }

    .error-msg {
      background: rgba(220, 38, 38, 0.15);
      border: 1px solid rgba(220,38,38,0.35);
      color: #fca5a5;
      border-radius: 0.625rem;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
    }

    button[type="submit"] {
      width: 100%;
      padding: 0.85rem 1rem;
      border-radius: 0.625rem;
      border: none;
      background: linear-gradient(135deg, #da8a1d 0%, #c47a18 100%);
      color: #fff;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      margin-top: 0.5rem;
    }

    button[type="submit"]:hover { opacity: 0.9; }
    button[type="submit"]:active { transform: scale(0.98); }

    .back-link {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: rgba(255,255,255,0.65); }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-logo">
      <img src="/images/logo.png" alt="Kebpro logó" />
      <span>Halasi Kebpro Kft.</span>
    </div>

    <h1>Admin belépés</h1>
    <p class="subtitle">Kizárólag jogosult felhasználók számára</p>

    <% if (error) { %>
    <div class="error-msg">&#9888; <%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <label for="username">Felhasználónév</label>
      <input id="username" name="username" type="text" autocomplete="username" autofocus required />

      <label for="password">Jelszó</label>
      <input id="password" name="password" type="password" autocomplete="current-password" required />

      <button type="submit">Belépés</button>
    </form>

    <a href="/" class="back-link">← Vissza a főoldalra</a>
  </div>
</body>
</html>
