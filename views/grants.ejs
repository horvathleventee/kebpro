<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.grants.eyebrow %></p>
    <h1><%= t.grants.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container grant-grid reveal-grid">
    <% grants.forEach((item) => { %>
    <article class="panel" data-stagger>
      <h2><%= item.title %></h2>
      <img src="<%= item.image %>" alt="<%= item.title %>" class="grant-image" />
      <p><strong><%= t.grants.projectTitle %>:</strong> <%= item.project %></p>
      <a class="btn btn-primary" href="<%= withLang(`/palyazatok/${item.slug}`) %>"><%= t.buttons.openDetails %></a>
    </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
