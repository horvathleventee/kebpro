<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.retail.eyebrow %></p>
    <h1><%= t.retail.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide retail-coming-panel">
      <div class="retail-coming-copy">
        <span class="timeline-intro-kicker"><%= t.retail.soon %></span>
        <h2><%= t.retail.text %></h2>
      </div>
      <figure class="retail-coming-image">
        <img
          src="/images/optimized/products/kiskereskedelem-640.jpg?v=<%= assetVersion || 'local' %>"
          srcset="/images/optimized/products/kiskereskedelem-640.jpg?v=<%= assetVersion || 'local' %> 640w, /images/optimized/products/kiskereskedelem-960.jpg?v=<%= assetVersion || 'local' %> 960w"
          sizes="(max-width: 720px) 92vw, 420px"
          alt="<%= t.retail.title %>"
          width="740"
          height="440"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </article>
  </div>
</section>

<%- include('partials/footer') %>
