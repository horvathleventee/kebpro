<%- include('partials/header') %>

<section class="hero section-animate">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow"><%= t.home.eyebrow %></p>
      <h1><%= t.home.title %></h1>
      <p class="lead"><%= t.home.lead %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
      </div>
    </div>
    <div class="hero-visual-wrap section-animate floating-visual">
      <img src="/images/gyrosnyars.png" alt="Gyros nyárs termékbemutató" class="hero-image" />
      <div class="hero-card hero-logo-card">
        <img src="/images/logo.png" alt="Kiskunhalasi Kebpro Kft. logó" class="hero-mini-logo" />
        <div>
          <h3><%= t.home.advantages %></h3>
          <ul>
            <% t.home.advantageItems.forEach((item) => { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.qualityHeading %></h2>
      <p><%= t.home.qualityLead %></p>
    </div>
    <div class="cards reveal-grid">
      <% t.home.qualityCards.forEach((card) => { %>
      <article class="card" data-stagger>
        <h3><%= card.title %></h3>
        <p><%= card.text %></p>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container logistics-layout">
    <div class="section-head logistics-copy">
      <p class="eyebrow"><%= t.home.logisticsEyebrow %></p>
      <h2><%= t.home.logisticsTitle %></h2>
      <p><%= t.home.logisticsLead %></p>
    </div>

    <div class="logistics-badges reveal-grid">
      <span class="logistics-badge" data-stagger>Országos hűtős kiszállítás</span>
      <span class="logistics-badge" data-stagger>Heti útvonaltervezés</span>
      <span class="logistics-badge" data-stagger>Rugalmas partnerkiszolgálás</span>
    </div>

    <div class="logistics-stats reveal-grid">
      <% t.home.logisticsStats.forEach((stat) => { %>
      <article class="stat-card panel" data-stagger>
        <span class="stat-label"><%= stat.label %></span>
        <strong><%= stat.value %></strong>
        <p><%= stat.text %></p>
      </article>
      <% }) %>
    </div>

    <div class="logistics-dashboard panel">
      <div class="dashboard-map">
        <div class="dashboard-glow dashboard-glow-a"></div>
        <div class="dashboard-glow dashboard-glow-b"></div>
        <svg viewBox="0 0 640 440" class="hungary-map strong-map" aria-hidden="true">
          <path d="M104 241 L150 180 L210 129 L273 117 L341 83 L414 105 L495 100 L559 156 L548 246 L585 287 L546 326 L474 338 L401 352 L328 389 L252 367 L200 316 L145 288 L115 243 Z" class="hungary-shape"></path>

          <path d="M138 218 L203 169 L252 148 L324 142 L375 132 L424 129 L487 151 L520 200 L516 243 L553 282 L521 314 L459 323 L390 336 L332 368 L265 350 L221 309 L167 277 L135 226 Z" class="region-overlay region-overlay-west" data-region-key="west"></path>
          <path d="M270 158 L322 145 L371 138 L409 146 L395 189 L332 205 L286 194 L259 175 Z" class="region-overlay region-overlay-central is-active" data-region-key="central"></path>
          <path d="M256 118 L315 91 L372 103 L421 112 L411 147 L364 139 L319 145 L280 154 L251 139 Z" class="region-overlay region-overlay-north" data-region-key="north"></path>
          <path d="M410 146 L489 149 L531 196 L526 239 L557 281 L523 314 L458 323 L398 297 L397 234 L403 187 Z" class="region-overlay region-overlay-east" data-region-key="east"></path>
          <path d="M221 309 L281 282 L345 287 L404 296 L458 323 L396 337 L331 368 L265 350 Z" class="region-overlay region-overlay-south" data-region-key="south"></path>

          <path d="M175 237 C225 198, 266 169, 329 173 C382 176, 432 152, 482 181" class="hungary-route strong-route"></path>
          <path d="M219 304 C263 276, 301 243, 356 251 C407 258, 451 259, 496 278" class="hungary-route strong-route"></path>
          <circle cx="188" cy="205" r="11" class="hungary-dot map-node map-node-west pulse-node"></circle>
          <circle cx="324" cy="177" r="12" class="hungary-dot map-node map-node-central is-active pulse-node"></circle>
          <circle cx="282" cy="124" r="11" class="hungary-dot map-node map-node-north pulse-node"></circle>
          <circle cx="472" cy="216" r="11" class="hungary-dot map-node map-node-east pulse-node"></circle>
          <circle cx="305" cy="296" r="11" class="hungary-dot map-node map-node-south pulse-node"></circle>
        </svg>

        <div class="dashboard-panel" id="logisticsPanel">
          <p class="logistics-panel-label"><%= t.home.logisticsPanelTitle %></p>
          <h3 id="logisticsPanelTitle"><%= activeRegion.title %></h3>
          <p id="logisticsPanelText"><%= activeRegion.text %></p>
        </div>
      </div>

      <div class="dashboard-side">
        <% logisticsRegions.forEach((region, index) => { %>
        <button
          type="button"
          class="region-chip region-card <%= index === 0 ? 'active' : '' %>"
          data-region-title="<%= region.title %>"
          data-region-text="<%= region.text %>"
          data-region-key="<%= region.key %>"
          data-stagger
        >
          <span class="region-chip-index">0<%= index + 1 %></span>
          <span class="region-card-copy">
            <strong><%= region.title %></strong>
            <small><%= region.text %></small>
          </span>
        </button>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.home.qualityPillarsTitle %></h2>
      <p><%= t.home.qualityPillarsText %></p>
      <a href="<%= withLang('/minoseg') %>" class="btn btn-secondary"><%= t.buttons.qualityDetails %></a>
    </article>
  </div>
</section>

<section class="section cta-strip section-animate">
  <div class="container cta-strip-inner">
    <h2><%= t.home.ctaTitle %></h2>
    <a href="<%= withLang('/kapcsolat') %>" class="btn btn-primary"><%= t.buttons.contact %></a>
  </div>
</section>

<%- include('partials/footer') %>

