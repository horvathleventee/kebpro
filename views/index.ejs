<%- include('partials/header') %>

<section class="hero section-animate">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow"><%= t.home.eyebrow %></p>
      <h1><%= t.home.title %></h1>
      <p class="lead"><%= t.home.lead %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
      </div>
    </div>
    <div class="hero-visual-wrap section-animate floating-visual">
      <img
        src="/images/optimized/gyrosnyars-640.jpg?v=<%= assetVersion || 'local' %>"
        srcset="/images/optimized/gyrosnyars-640.jpg?v=<%= assetVersion || 'local' %> 640w, /images/optimized/gyrosnyars-960.jpg?v=<%= assetVersion || 'local' %> 960w"
        sizes="(max-width: 768px) calc(100vw - 2rem), 490px"
        alt="Gyros ny&aacute;rs term&eacute;kbemutat&oacute;"
        class="hero-image"
        width="640"
        height="960"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-card hero-logo-card">
        <img src="/images/optimized/logo-170.png?v=<%= assetVersion || 'local' %>" alt="Halasi Kebpro Kft. log&oacute;" class="hero-mini-logo" width="170" height="79" loading="lazy" decoding="async" />
        <div>
          <h3><%= t.home.advantages %></h3>
          <ul>
            <% t.home.advantageItems.forEach((item) => { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.qualityHeading %></h2>
      <p><%= t.home.qualityLead %></p>
    </div>
    <div class="cards reveal-grid">
      <% const qualityIcons = [
        '<svg class="card-icon icon-shield" viewBox="0 0 36 42" fill="none" aria-hidden="true"><path d="M18 2L4 9v11c0 9.4 6 16.2 14 19 8-2.8 14-9.6 14-19V9L18 2z" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linejoin="round"/><path d="M18 6L8 11v8c0 7.2 4.6 12.5 10 14.6" fill="var(--primary)" opacity="0.06"/><path class="shield-check" d="M12 21l4.5 4.5L25 16" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
        '<svg class="card-icon icon-snowflake" viewBox="0 0 40 40" fill="none" aria-hidden="true"><g stroke="var(--primary)" stroke-width="1.8" stroke-linecap="round"><line x1="20" y1="2" x2="20" y2="38"/><line x1="2" y1="20" x2="38" y2="20"/><line x1="7.3" y1="7.3" x2="32.7" y2="32.7"/><line x1="32.7" y1="7.3" x2="7.3" y2="32.7"/><line x1="20" y1="2" x2="16" y2="6"/><line x1="20" y1="2" x2="24" y2="6"/><line x1="20" y1="38" x2="16" y2="34"/><line x1="20" y1="38" x2="24" y2="34"/><line x1="2" y1="20" x2="6" y2="16"/><line x1="2" y1="20" x2="6" y2="24"/><line x1="38" y1="20" x2="34" y2="16"/><line x1="38" y1="20" x2="34" y2="24"/><line x1="7.3" y1="7.3" x2="10.5" y2="4.8"/><line x1="7.3" y1="7.3" x2="4.8" y2="10.5"/><line x1="32.7" y1="32.7" x2="29.5" y2="35.2"/><line x1="32.7" y1="32.7" x2="35.2" y2="29.5"/><line x1="32.7" y1="7.3" x2="35.2" y2="10.5"/><line x1="32.7" y1="7.3" x2="29.5" y2="4.8"/><line x1="7.3" y1="32.7" x2="4.8" y2="29.5"/><line x1="7.3" y1="32.7" x2="10.5" y2="35.2"/></g><circle cx="20" cy="20" r="3" fill="var(--accent)" opacity="0.25"/></svg>',
        '<svg class="card-icon icon-clipboard" viewBox="0 0 34 42" fill="none" aria-hidden="true"><rect x="3" y="6" width="28" height="33" rx="4" fill="none" stroke="var(--primary)" stroke-width="2"/><rect x="11" y="2" width="12" height="7" rx="2.5" fill="var(--primary)" opacity="0.15" stroke="var(--primary)" stroke-width="1.5"/><circle cx="11" cy="19" r="1.5" fill="var(--accent)"/><line class="clip-line clip-line-1" x1="15" y1="19" x2="26" y2="19" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="26" r="1.5" fill="var(--accent)"/><line class="clip-line clip-line-2" x1="15" y1="26" x2="23" y2="26" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="33" r="1.5" fill="var(--accent)"/><line class="clip-line clip-line-3" x1="15" y1="33" x2="20" y2="33" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round"/></svg>'
      ]; %>
      <% t.home.qualityCards.forEach((card, idx) => { %>
      <article class="card" data-stagger>
        <%- qualityIcons[idx] || '' %>
        <h3><%= card.title %></h3>
        <p><%= card.text %></p>
      </article>
      <% }) %>
    </div>
    <% if (t.home.productsIntro) { %>
    <p class="products-intro-text">
      <%= t.home.productsIntro %>
      <a href="<%= withLang('/termekek/horeca') %>" class="inline-link"><%= t.home.productsLink %> →</a>
    </p>
    <% } %>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.home.qualityPillarsTitle %></h2>
      <p><%= t.home.qualityPillarsText %></p>
      <a href="<%= withLang('/minoseg') %>" class="btn btn-secondary"><%= t.buttons.qualityDetails %></a>
    </article>
  </div>
</section>

<!-- Logisztika — teljes interaktív térkép -->
<section class="section alt section-animate" id="logisztika">
  <div class="container logistics-layout">
    <div class="section-head logistics-copy">
      <!-- Refrigerated truck icon -->
      <svg class="section-icon icon-truck" viewBox="0 0 56 32" fill="none" aria-hidden="true"><rect x="1" y="4" width="30" height="19" rx="3" stroke="var(--primary)" stroke-width="2" fill="var(--surface-alt)"/><path d="M31 10h9a3 3 0 012.12.88l5 5A3 3 0 0148 17.12V23H31V10z" stroke="var(--primary)" stroke-width="2" fill="var(--surface-alt)"/><line x1="31" y1="10" x2="31" y2="23" stroke="var(--primary)" stroke-width="2"/><circle class="truck-wheel" cx="11" cy="26" r="4" fill="var(--primary)" stroke="var(--primary)" stroke-width="1.5"/><circle cx="11" cy="26" r="1.5" fill="#fff"/><circle class="truck-wheel" cx="41" cy="26" r="4" fill="var(--primary)" stroke="var(--primary)" stroke-width="1.5"/><circle cx="41" cy="26" r="1.5" fill="#fff"/><line x1="1" y1="23" x2="7" y2="23" stroke="var(--primary)" stroke-width="2"/><line x1="15" y1="23" x2="31" y2="23" stroke="var(--primary)" stroke-width="2"/><line x1="45" y1="23" x2="48" y2="23" stroke="var(--primary)" stroke-width="2"/><path d="M12 9v8M17 9v8M22 9v8" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/><rect x="35" y="13" width="6" height="4" rx="1" fill="rgba(16,36,63,0.1)" stroke="var(--primary)" stroke-width="1"/></svg>
      <p class="eyebrow"><%= t.home.logisticsEyebrow %></p>
      <h2><%= t.home.logisticsTitle %></h2>
      <p><%= t.home.logisticsLead %></p>
    </div>

    <% if (t.home.logisticsBadges && t.home.logisticsBadges.length) { %>
    <div class="logistics-badges reveal-grid">
      <% t.home.logisticsBadges.forEach((badge) => { %>
      <span class="logistics-badge" data-stagger><%= badge %></span>
      <% }) %>
    </div>
    <% } %>

    <% if (t.home.logisticsStats && t.home.logisticsStats.length) { %>
    <div class="logistics-stats reveal-grid">
      <% t.home.logisticsStats.forEach((stat) => { %>
      <article class="stat-card panel" data-stagger>
        <span class="stat-label"><%= stat.label %></span>
        <strong class="count-up" data-target="<%= stat.value %>"><%= stat.value %></strong>
        <p><%= stat.text %></p>
      </article>
      <% }) %>
    </div>
    <% } %>

    <div class="zip-checker">
      <div class="zip-input-wrap">
        <input type="text" id="zipInput" class="zip-input" placeholder="<%= t.home.zipPlaceholder %>" maxlength="4" inputmode="numeric" autocomplete="off" />
        <span class="zip-result" id="zipResult"></span>
      </div>
      <span class="zip-labels" data-zip-result="<%= t.home.zipResult %>" data-zip-not-found="<%= t.home.zipNotFound %>"></span>
    </div>

    <div class="logistics-dashboard panel">
      <div class="dashboard-map">
        <div class="dashboard-glow dashboard-glow-a"></div>
        <div class="dashboard-glow dashboard-glow-b"></div>
        <%- include('partials/hungary-map') %>
        <div class="dashboard-panel <%= activeRegion.panelPosition || 'panel-bottom-right' %>" id="logisticsPanel">
          <p class="logistics-panel-label"><%= t.home.logisticsPanelTitle %></p>
          <% if (activeRegion.schedule) { %>
          <p class="logistics-schedule" id="logisticsPanelSchedule"><%= activeRegion.schedule %></p>
          <% } else { %>
          <p class="logistics-schedule" id="logisticsPanelSchedule"></p>
          <% } %>
          <h3 id="logisticsPanelTitle"><%= activeRegion.title %></h3>
          <p id="logisticsPanelText"><%= activeRegion.text %></p>
        </div>
      </div>
      <div class="dashboard-side">
        <% logisticsRegions.forEach((region, index) => { %>
        <button
          type="button"
          class="region-chip region-card <%= index === 0 ? 'active' : '' %>"
          data-region-title="<%= region.title %>"
          data-region-text="<%= region.text %>"
          data-region-schedule="<%= region.schedule || '' %>"
          data-region-key="<%= region.key %>"
          data-panel-position="<%= region.panelPosition || 'panel-bottom-right' %>"
          data-stagger
        >
          <span class="region-chip-index">0<%= index + 1 %></span>
          <span class="region-card-copy">
            <strong><%= region.title %></strong>
            <% if (region.schedule) { %>
            <span class="region-card-schedule"><%= region.schedule %></span>
            <% } %>
            <small><%= region.text %></small>
          </span>
        </button>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<% if (t.home.faqItems && t.home.faqItems.length) { %>
<section class="section alt section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.faqTitle %></h2>
    </div>
    <div class="faq-list" id="faqList">
      <% t.home.faqItems.forEach((item, i) => { %>
      <details class="faq-item <%= i >= 2 ? 'faq-hidden' : '' %>">
        <summary class="faq-question"><%= item.q %></summary>
        <p class="faq-answer"><%= item.a %></p>
      </details>
      <% }) %>
      <% if (t.home.faqItems.length > 2) { %>
      <button type="button" class="btn btn-secondary faq-toggle" id="faqToggle" data-show="<%= t.home.faqShowMore %>" data-hide="<%= t.home.faqShowLess %>"><%= t.home.faqShowMore %></button>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<% if (t.home.ctaQuoteText) { %>
<section class="section section-animate">
  <div class="container cta-panels reveal-grid">
    <article class="panel cta-panel" data-stagger>
      <h2><%= t.home.ctaQuoteTitle %></h2>
      <p><%= t.home.ctaQuoteText %></p>
      <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
    </article>
    <article class="panel cta-panel" data-stagger>
      <h2><%= t.home.ctaOrderTitle %></h2>
      <p><%= t.home.ctaOrderText %></p>
      <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
    </article>
  </div>
</section>
<% } %>

<section class="section cta-strip section-animate">
  <div class="container cta-strip-inner">
    <h2><%= t.home.ctaTitle %></h2>
    <a href="<%= withLang('/kapcsolat') %>" class="btn btn-primary"><%= t.buttons.contact %></a>
  </div>
</section>

<%- include('partials/footer') %>
