<%- include('partials/header') %>

<section class="hero section-animate">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow"><%= t.home.eyebrow %></p>
      <h1><%= t.home.title %></h1>
      <p class="lead"><%= t.home.lead %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
      </div>
    </div>
    <div class="hero-visual-wrap section-animate floating-visual">
      <img src="/images/gyrosnyars.png" alt="Gyros ny&aacute;rs term&eacute;kbemutat&oacute;" class="hero-image" />
      <div class="hero-card hero-logo-card">
        <img src="/images/logo.png" alt="Halasi Kebpro Kft. log&oacute;" class="hero-mini-logo" />
        <div>
          <h3><%= t.home.advantages %></h3>
          <ul>
            <% t.home.advantageItems.forEach((item) => { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.qualityHeading %></h2>
      <p><%= t.home.qualityLead %></p>
    </div>
    <div class="cards reveal-grid">
      <% t.home.qualityCards.forEach((card) => { %>
      <article class="card" data-stagger>
        <h3><%= card.title %></h3>
        <p><%= card.text %></p>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section alt section-animate" id="logisztika">
  <div class="container logistics-short-grid">
    <div class="logistics-short-copy">
      <p class="eyebrow"><%= t.home.logisticsEyebrow %></p>
      <h2><%= t.home.logisticsTitle %></h2>
      <p class="lead"><%= t.home.logisticsLead %></p>
      <a href="<%= withLang('/rolunk') %>" class="btn btn-secondary"><%= t.buttons.logisticsDetails %></a>
    </div>
    <% if (t.home.logisticsStats && t.home.logisticsStats.length) { %>
    <div class="logistics-short-stats reveal-grid">
      <% t.home.logisticsStats.forEach((stat) => { %>
      <article class="stat-card panel" data-stagger>
        <span class="stat-label"><%= stat.label %></span>
        <strong><%= stat.value %></strong>
        <p><%= stat.text %></p>
      </article>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.home.qualityPillarsTitle %></h2>
      <p><%= t.home.qualityPillarsText %></p>
      <a href="<%= withLang('/minoseg') %>" class="btn btn-secondary"><%= t.buttons.qualityDetails %></a>
    </article>
  </div>
</section>

<section class="section cta-strip section-animate">
  <div class="container cta-strip-inner">
    <h2><%= t.home.ctaTitle %></h2>
    <a href="<%= withLang('/kapcsolat') %>" class="btn btn-primary"><%= t.buttons.contact %></a>
  </div>
</section>

<%- include('partials/footer') %>
