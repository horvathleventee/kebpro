<%- include('partials/header') %>

<%
  const logisticsBadges = t.home.logisticsBadges || (lang === 'de'
    ? ['Landesweite K\u00fchlzustellung', 'W\u00f6chentliche Routenplanung', 'Flexible Partnerbelieferung']
    : lang === 'en'
      ? ['Nationwide refrigerated delivery', 'Weekly route planning', 'Flexible partner service']
      : ['Orsz\u00e1gos h\u0171t\u0151s kisz\u00e1ll\u00edt\u00e1s', 'Heti \u00fatvonaltervez\u00e9s', 'Rugalmas partnerkiszolg\u00e1l\u00e1s']);

  const logisticsStats = t.home.logisticsStats || (lang === 'de'
    ? [
        { label: 'Abdeckung', value: 'Ungarn', text: 'Landesweite Partnerbelieferung mit eigener K\u00fchlflotte.' },
        { label: 'Taktung', value: 'W\u00f6chentlich', text: 'W\u00f6chentlich geplante Routen mit mehreren Fahrten an priorisierten Punkten.' },
        { label: 'K\u00fchlkette', value: 'Kontrolliert', text: 'Durchgehend \u00fcberwachte K\u00fchlkette und abgestimmter Lieferrhythmus bis zur \u00dcbergabe.' },
      ]
    : lang === 'en'
      ? [
          { label: 'Coverage', value: 'Hungary', text: 'Nationwide partner service with our own refrigerated fleet.' },
          { label: 'Routing', value: 'Weekly', text: 'Weekly scheduled routes with multiple rounds at priority points.' },
          { label: 'Cold chain', value: 'Controlled', text: 'Tracked cold-chain handling and coordinated delivery rhythm until handover.' },
        ]
      : [
          { label: 'Lefedetts\u00e9g', value: 'Magyarorsz\u00e1g', text: 'Orsz\u00e1gos partnerkiszolg\u00e1l\u00e1s saj\u00e1t h\u0171t\u0151s flott\u00e1val.' },
          { label: '\u00dctemez\u00e9s', value: 'Heti', text: 'Heti \u00fctemezett \u00fatvonalak, kiemelt pontokon t\u00f6bbsz\u00f6ri fordul\u00f3val.' },
          { label: 'H\u0171t\u0151l\u00e1nc', value: 'Ellen\u0151rz\u00f6tt', text: '\u00c1tad\u00e1sig k\u00f6vetett h\u0171t\u0151l\u00e1nc \u00e9s egyeztetett kisz\u00e1ll\u00edt\u00e1si ritmus.' },
        ]);
%>

<section class="hero section-animate">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow"><%= t.home.eyebrow %></p>
      <h1><%= t.home.title %></h1>
      <p class="lead"><%= t.home.lead %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
      </div>
    </div>
    <div class="hero-visual-wrap section-animate floating-visual">
      <img src="/images/gyrosnyars.png" alt="Gyros ny&aacute;rs term&eacute;kbemutat&oacute;" class="hero-image" />
      <div class="hero-card hero-logo-card">
        <img src="/images/logo.png" alt="Kiskunhalasi Kebpro Kft. log&oacute;" class="hero-mini-logo" />
        <div>
          <h3><%= t.home.advantages %></h3>
          <ul>
            <% t.home.advantageItems.forEach((item) => { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.qualityHeading %></h2>
      <p><%= t.home.qualityLead %></p>
    </div>
    <div class="cards reveal-grid">
      <% t.home.qualityCards.forEach((card) => { %>
      <article class="card" data-stagger>
        <h3><%= card.title %></h3>
        <p><%= card.text %></p>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container logistics-layout">
    <div class="section-head logistics-copy">
      <p class="eyebrow"><%= t.home.logisticsEyebrow %></p>
      <h2><%= t.home.logisticsTitle %></h2>
      <p><%= t.home.logisticsLead %></p>
    </div>

    <div class="logistics-badges reveal-grid">
      <% logisticsBadges.forEach((badge) => { %>
      <span class="logistics-badge" data-stagger><%= badge %></span>
      <% }) %>
    </div>

    <div class="logistics-stats reveal-grid">
      <% logisticsStats.forEach((stat) => { %>
      <article class="stat-card panel" data-stagger>
        <span class="stat-label"><%= stat.label %></span>
        <strong><%= stat.value %></strong>
        <p><%= stat.text %></p>
      </article>
      <% }) %>
    </div>

    <div class="logistics-dashboard panel">
      <div class="dashboard-map">
        <div class="dashboard-glow dashboard-glow-a"></div>
        <div class="dashboard-glow dashboard-glow-b"></div>
        <%- include('partials/hungary-map') %>

<div class="dashboard-panel" id="logisticsPanel">
          <p class="logistics-panel-label"><%= t.home.logisticsPanelTitle %></p>
          <h3 id="logisticsPanelTitle"><%= activeRegion.title %></h3>
          <p id="logisticsPanelText"><%= activeRegion.text %></p>
        </div>
      </div>

      <div class="dashboard-side">
        <% logisticsRegions.forEach((region, index) => { %>
        <button
          type="button"
          class="region-chip region-card <%= index === 0 ? 'active' : '' %>"
          data-region-title="<%= region.title %>"
          data-region-text="<%= region.text %>"
          data-region-key="<%= region.key %>"
          data-stagger
        >
          <span class="region-chip-index">0<%= index + 1 %></span>
          <span class="region-card-copy">
            <strong><%= region.title %></strong>
            <small><%= region.text %></small>
          </span>
        </button>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.home.qualityPillarsTitle %></h2>
      <p><%= t.home.qualityPillarsText %></p>
      <a href="<%= withLang('/minoseg') %>" class="btn btn-secondary"><%= t.buttons.qualityDetails %></a>
    </article>
  </div>
</section>

<section class="section cta-strip section-animate">
  <div class="container cta-strip-inner">
    <h2><%= t.home.ctaTitle %></h2>
    <a href="<%= withLang('/kapcsolat') %>" class="btn btn-primary"><%= t.buttons.contact %></a>
  </div>
</section>

<%- include('partials/footer') %>
