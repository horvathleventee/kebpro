<%- include('partials/header') %>

<section class="hero section-animate">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow"><%= t.home.eyebrow %></p>
      <h1><%= t.home.title %></h1>
      <p class="lead"><%= t.home.lead %></p>
      <div class="hero-actions">
        <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
        <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
      </div>
    </div>
    <div class="hero-visual-wrap section-animate floating-visual">
      <img src="/images/gyrosnyars.png" alt="Gyros ny&aacute;rs term&eacute;kbemutat&oacute;" class="hero-image" />
      <div class="hero-card hero-logo-card">
        <img src="/images/logo.png" alt="Halasi Kebpro Kft. log&oacute;" class="hero-mini-logo" />
        <div>
          <h3><%= t.home.advantages %></h3>
          <ul>
            <% t.home.advantageItems.forEach((item) => { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Logisztika — teljes interaktív térkép -->
<section class="section alt section-animate" id="logisztika">
  <div class="container logistics-layout">
    <div class="section-head logistics-copy">
      <!-- Animated truck icon -->
      <svg class="section-icon icon-truck" viewBox="0 0 64 40" fill="none" aria-hidden="true"><rect class="truck-body" x="2" y="6" width="36" height="22" rx="4" fill="var(--primary)" opacity="0.9"/><path class="truck-cab" d="M38 14h10l8 10v4a4 4 0 01-4 4h-14V14z" fill="var(--primary-light)"/><circle class="truck-wheel truck-wheel-rear" cx="14" cy="32" r="5" fill="var(--accent)"/><circle class="truck-wheel truck-wheel-front" cx="48" cy="32" r="5" fill="var(--accent)"/><rect x="8" y="12" width="12" height="3" rx="1.5" fill="#fff" opacity="0.3"/><rect x="8" y="18" width="8" height="2" rx="1" fill="#fff" opacity="0.2"/></svg>
      <p class="eyebrow"><%= t.home.logisticsEyebrow %></p>
      <h2><%= t.home.logisticsTitle %></h2>
      <p><%= t.home.logisticsLead %></p>
    </div>

    <% if (t.home.logisticsBadges && t.home.logisticsBadges.length) { %>
    <div class="logistics-badges reveal-grid">
      <% t.home.logisticsBadges.forEach((badge) => { %>
      <span class="logistics-badge" data-stagger><%= badge %></span>
      <% }) %>
    </div>
    <% } %>

    <% if (t.home.logisticsStats && t.home.logisticsStats.length) { %>
    <div class="logistics-stats reveal-grid">
      <% t.home.logisticsStats.forEach((stat) => { %>
      <article class="stat-card panel" data-stagger>
        <span class="stat-label"><%= stat.label %></span>
        <strong class="count-up" data-target="<%= stat.value %>"><%= stat.value %></strong>
        <p><%= stat.text %></p>
      </article>
      <% }) %>
    </div>
    <% } %>

    <div class="logistics-dashboard panel">
      <div class="dashboard-map">
        <div class="dashboard-glow dashboard-glow-a"></div>
        <div class="dashboard-glow dashboard-glow-b"></div>
        <%- include('partials/hungary-map') %>
        <div class="dashboard-panel <%= activeRegion.panelPosition || 'panel-bottom-right' %>" id="logisticsPanel">
          <p class="logistics-panel-label"><%= t.home.logisticsPanelTitle %></p>
          <h3 id="logisticsPanelTitle"><%= activeRegion.title %></h3>
          <p id="logisticsPanelText"><%= activeRegion.text %></p>
        </div>
      </div>
      <div class="dashboard-side">
        <% logisticsRegions.forEach((region, index) => { %>
        <button
          type="button"
          class="region-chip region-card <%= index === 0 ? 'active' : '' %>"
          data-region-title="<%= region.title %>"
          data-region-text="<%= region.text %>"
          data-region-key="<%= region.key %>"
          data-panel-position="<%= region.panelPosition || 'panel-bottom-right' %>"
          data-stagger
        >
          <span class="region-chip-index">0<%= index + 1 %></span>
          <span class="region-card-copy">
            <strong><%= region.title %></strong>
            <small><%= region.text %></small>
          </span>
        </button>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.home.qualityHeading %></h2>
      <p><%= t.home.qualityLead %></p>
    </div>
    <div class="cards reveal-grid">
      <% const qualityIcons = [
        '<svg class="card-icon icon-shield" viewBox="0 0 40 44" fill="none" aria-hidden="true"><path class="shield-body" d="M20 2L4 10v12c0 10 7 17 16 20 9-3 16-10 16-20V10L20 2z" fill="var(--primary)" opacity="0.12" stroke="var(--primary)" stroke-width="2"/><path class="shield-check" d="M13 22l5 5 9-10" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
        '<svg class="card-icon icon-snowflake" viewBox="0 0 40 40" fill="none" aria-hidden="true"><line x1="20" y1="4" x2="20" y2="36" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"/><line x1="4" y1="20" x2="36" y2="20" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"/><line x1="8.7" y1="8.7" x2="31.3" y2="31.3" stroke="var(--primary)" stroke-width="2" stroke-linecap="round"/><line x1="31.3" y1="8.7" x2="8.7" y2="31.3" stroke="var(--primary)" stroke-width="2" stroke-linecap="round"/><circle cx="20" cy="4" r="2" fill="var(--accent)"/><circle cx="20" cy="36" r="2" fill="var(--accent)"/><circle cx="4" cy="20" r="2" fill="var(--accent)"/><circle cx="36" cy="20" r="2" fill="var(--accent)"/></svg>',
        '<svg class="card-icon icon-clipboard" viewBox="0 0 36 44" fill="none" aria-hidden="true"><rect x="4" y="6" width="28" height="34" rx="4" fill="var(--primary)" opacity="0.12" stroke="var(--primary)" stroke-width="2"/><rect class="clip-top" x="11" y="2" width="14" height="8" rx="3" fill="var(--primary)" opacity="0.9"/><line class="clip-line clip-line-1" x1="10" y1="20" x2="26" y2="20" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/><line class="clip-line clip-line-2" x1="10" y1="26" x2="22" y2="26" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/><line class="clip-line clip-line-3" x1="10" y1="32" x2="18" y2="32" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/></svg>'
      ]; %>
      <% t.home.qualityCards.forEach((card, idx) => { %>
      <article class="card" data-stagger>
        <%- qualityIcons[idx] || '' %>
        <h3><%= card.title %></h3>
        <p><%= card.text %></p>
      </article>
      <% }) %>
    </div>
    <% if (t.home.productsIntro) { %>
    <p class="products-intro-text">
      <%= t.home.productsIntro %>
      <a href="<%= withLang('/termekek/nagykereskedelem') %>" class="inline-link"><%= t.home.productsLink %> →</a>
    </p>
    <% } %>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.home.qualityPillarsTitle %></h2>
      <p><%= t.home.qualityPillarsText %></p>
      <a href="<%= withLang('/minoseg') %>" class="btn btn-secondary"><%= t.buttons.qualityDetails %></a>
    </article>
  </div>
</section>

<% if (t.home.ctaQuoteText) { %>
<section class="section section-animate">
  <div class="container cta-panels reveal-grid">
    <article class="panel cta-panel" data-stagger>
      <h2><%= t.home.ctaQuoteTitle %></h2>
      <p><%= t.home.ctaQuoteText %></p>
      <a href="<%= withLang('/ajanlatkeres') %>" class="btn btn-primary"><%= t.buttons.quote %></a>
    </article>
    <article class="panel cta-panel" data-stagger>
      <h2><%= t.home.ctaOrderTitle %></h2>
      <p><%= t.home.ctaOrderText %></p>
      <a href="<%= withLang('/megrendeles') %>" class="btn btn-secondary"><%= t.buttons.order %></a>
    </article>
  </div>
</section>
<% } %>

<section class="section cta-strip section-animate">
  <div class="container cta-strip-inner">
    <h2><%= t.home.ctaTitle %></h2>
    <a href="<%= withLang('/kapcsolat') %>" class="btn btn-primary"><%= t.buttons.contact %></a>
  </div>
</section>

<%- include('partials/footer') %>
