<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Kiskunhalasi Kebpro Kft. gyros- és kebab hús gyártás, nagykereskedelem"
    />
    <title><%= title %> | <%= company.name %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a href="/" class="brand">
          <img src="/images/logo.png" alt="Kebpro logó" class="brand-logo" />
          <span>Kiskunhalasi Kebpro Kft.</span>
        </a>

        <button class="menu-toggle" id="menuToggle" aria-label="Menü megnyitása">
          <span></span><span></span><span></span>
        </button>

        <nav class="main-nav" id="mainNav">
          <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Főoldal</a>
          <a href="/rolunk" class="<%= currentPath === '/rolunk' ? 'active' : '' %>">Rólunk</a>
          <a href="/minoseg" class="<%= currentPath === '/minoseg' ? 'active' : '' %>">Minőség</a>

          <div class="nav-dropdown <%= currentPath.startsWith('/termekek') ? 'active' : '' %>">
            <button class="dropdown-toggle" type="button">Termékek</button>
            <div class="dropdown-menu">
              <a href="/termekek/nagykereskedelem">Nagykereskedelem</a>
              <a href="/termekek/kiskereskedelem">Kiskereskedelem</a>
            </div>
          </div>

          <div class="nav-dropdown <%= currentPath.startsWith('/palyazatok') ? 'active' : '' %>">
            <button class="dropdown-toggle" type="button">Pályázatok</button>
            <div class="dropdown-menu">
              <a href="/palyazatok/vp3-4.2.1-4.2.2-2-21">VP3-4.2.1-4.2.2-2-21</a>
              <a href="/palyazatok/vp-3-4.2.1-15">VP-3-4.2.1-15</a>
            </div>
          </div>

          <a href="/ajanlatkeres" class="<%= currentPath === '/ajanlatkeres' ? 'active' : '' %>">Ajánlatkérés</a>
          <a href="/megrendeles" class="<%= currentPath === '/megrendeles' ? 'active' : '' %>">Megrendelés</a>
          <a href="/kapcsolat" class="cta-link <%= currentPath === '/kapcsolat' ? 'active' : '' %>">Kapcsolat</a>
        </nav>
      </div>
    </header>

    <main>
