<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <% 
      const pageSeo = typeof seo !== 'undefined' ? seo : null;
      const companyName = company?.name || 'Halasi Kebpro Kft.';
      const pageTitle = pageSeo?.title ? pageSeo.title : `${title} | ${companyName}`;
      const pageDescription = pageSeo?.description ? pageSeo.description : companyName;
      const pageOgImage = pageSeo?.ogImage ? pageSeo.ogImage : '/images/og-default.jpg';
    %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title><%= pageTitle %></title>
    <meta name="description" content="<%= pageDescription %>" />
    <% if (pageSeo && pageSeo.canonical) { %>
    <link rel="canonical" href="<%= pageSeo.canonical %>" />
    <% } %>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="<%= companyName %>" />
    <meta property="og:title" content="<%= pageTitle %>" />
    <meta property="og:description" content="<%= pageDescription %>" />
    <% if (pageSeo && pageSeo.canonical) { %><meta property="og:url" content="<%= pageSeo.canonical %>" /><% } %>
    <meta property="og:image" content="<%= pageOgImage %>" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <header class="site-header">
      <div class="container header-shell">
        <div class="header-main">
          <a href="<%= withLang('/') %>" class="brand">
            <img src="/images/logo.png" alt="Kebpro logó" class="brand-logo" />
            <span>Halasi Kebpro Kft.</span>
          </a>

          <button class="menu-toggle" id="menuToggle" aria-label="Menü megnyitása">
            <span></span><span></span><span></span>
          </button>

          <nav class="main-nav" id="mainNav">
            <div class="nav-cluster">
              <a href="<%= withLang('/') %>" class="<%= currentPath === '/' ? 'active' : '' %>"><%= t.nav.home %></a>
              <a href="<%= withLang('/rolunk') %>" class="<%= currentPath === '/rolunk' ? 'active' : '' %>"><%= t.nav.about %></a>
              <a href="<%= withLang('/minoseg') %>" class="<%= currentPath === '/minoseg' ? 'active' : '' %>"><%= t.nav.quality %></a>

              <div class="nav-dropdown <%= currentPath.startsWith('/termekek') ? 'active' : '' %>">
                <a href="<%= withLang('/termekek') %>" class="dropdown-toggle"><%= t.nav.products %></a>
                <div class="dropdown-menu">
                  <a href="<%= withLang('/termekek/horeca') %>"><%= t.nav.wholesale %></a>
                  <a href="<%= withLang('/termekek/kiskereskedelem') %>"><%= t.nav.retail %></a>
                </div>
              </div>

              <div class="nav-dropdown <%= currentPath.startsWith('/palyazatok') ? 'active' : '' %>">
                <a href="<%= withLang('/palyazatok') %>" class="dropdown-toggle"><%= t.nav.grants %></a>
                <div class="dropdown-menu">
                  <a href="<%= withLang('/palyazatok/vp3-4.2.1-4.2.2-2-21') %>">VP3-4.2.1-4.2.2-2-21</a>
                  <a href="<%= withLang('/palyazatok/vp-3-4.2.1-15') %>">VP-3-4.2.1-15</a>
                </div>
              </div>

              <a href="<%= withLang('/ajanlatkeres') %>" class="<%= currentPath === '/ajanlatkeres' ? 'active' : '' %>"><%= t.nav.quote %></a>
              <a href="<%= withLang('/megrendeles') %>" class="<%= currentPath === '/megrendeles' ? 'active' : '' %>"><%= t.nav.order %></a>
              <a href="<%= withLang('/karrier') %>" class="<%= currentPath === '/karrier' ? 'active' : '' %>"><%= t.nav.career %></a>
            </div>

            <div class="header-utilities">
              <a href="<%= withLang('/kapcsolat') %>" class="cta-link <%= currentPath === '/kapcsolat' ? 'active' : '' %>"><%= t.nav.contact %></a>
              <div class="lang-switcher" aria-label="Nyelvválasztó">
                <% supportedLanguages.forEach((item) => { %>
                <a href="<%= buildLangUrl(currentPath, item) %>" class="lang-pill <%= lang === item ? 'active' : '' %>"><%= item.toUpperCase() %></a>
                <% }) %>
              </div>
            </div>
          </nav>
        </div>
      </div>
    </header>

    <main>
