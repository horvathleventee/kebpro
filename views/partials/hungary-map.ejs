<div class="hungary-map-shell">
  <img
    src="/images/optimized/hungary-logistics-map-768.jpg?v=<%= assetVersion || 'local' %>"
    srcset="/images/optimized/hungary-logistics-map-768.jpg?v=<%= assetVersion || 'local' %> 768w, /images/optimized/hungary-logistics-map-1100.jpg?v=<%= assetVersion || 'local' %> 1100w"
    sizes="(max-width: 768px) calc(100vw - 3rem), 594px"
    alt="Magyarország logisztikai térképe"
    class="hungary-map-image"
    width="768"
    height="512"
    loading="lazy"
    decoding="async"
  />

  <button type="button" class="map-node map-node-north-hungary" data-region-key="northHungary" style="left: 63%; top: 32%;" aria-label="Észak-Magyarország"></button>
  <button type="button" class="map-node map-node-north-alfold" data-region-key="northAlfold" style="left: 72%; top: 50%;" aria-label="Észak-Alföld"></button>
  <button type="button" class="map-node map-node-south-alfold" data-region-key="southAlfold" style="left: 50%; top: 66%;" aria-label="Dél-Alföld"></button>
  <button type="button" class="map-node map-node-central-west-dunantul" data-region-key="centralWestDunantul" style="left: 18%; top: 49%;" aria-label="Közép-Nyugat-Dunántúl"></button>
  <button type="button" class="map-node map-node-south-dunantul" data-region-key="southDunantul" style="left: 27%; top: 65%;" aria-label="Dél-Dunántúl"></button>
  <button type="button" class="map-node map-node-central-hungary" data-region-key="centralHungary" style="left: 48%; top: 45%;" aria-label="Közép-Magyarország"></button>
  <button type="button" class="map-node map-node-balaton" data-region-key="balaton" style="left: 30%; top: 56%;" aria-label="Balaton térsége"></button>
</div>
