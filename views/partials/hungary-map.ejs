<div class="hungary-map-shell">
  <img
    src="/images/optimized/hungary-logistics-map-768.jpg?v=<%= assetVersion || 'local' %>"
    srcset="/images/optimized/hungary-logistics-map-768.jpg?v=<%= assetVersion || 'local' %> 768w, /images/optimized/hungary-logistics-map-1100.jpg?v=<%= assetVersion || 'local' %> 1100w"
    sizes="(max-width: 768px) calc(100vw - 3rem), 594px"
    alt="Magyarország logisztikai térképe"
    class="hungary-map-image"
    width="768"
    height="512"
    loading="lazy"
    decoding="async"
  />

  <button type="button" class="map-node map-node-north-hungary" data-region-key="northHungary" style="left: 62%; top: 25%;" aria-label="Észak-Magyarország"></button>
  <button type="button" class="map-node map-node-north-alfold" data-region-key="northAlfold" style="left: 77%; top: 40%;" aria-label="Észak-Alföld"></button>
  <button type="button" class="map-node map-node-south-alfold" data-region-key="southAlfold" style="left: 55%; top: 76%;" aria-label="Dél-Alföld"></button>
  <button type="button" class="map-node map-node-central-dunantul" data-region-key="centralDunantul" style="left: 33%; top: 42%;" aria-label="Közép-Dunántúl"></button>
  <button type="button" class="map-node map-node-west-dunantul" data-region-key="westDunantul" style="left: 11%; top: 59%;" aria-label="Nyugat-Dunántúl"></button>
  <button type="button" class="map-node map-node-south-dunantul" data-region-key="southDunantul" style="left: 26%; top: 81%;" aria-label="Dél-Dunántúl"></button>
  <button type="button" class="map-node map-node-central-hungary" data-region-key="centralHungary" style="left: 49%; top: 46%;" aria-label="Közép-Magyarország"></button>
  <button type="button" class="map-node map-node-balaton" data-region-key="balaton" style="left: 30%; top: 63%;" aria-label="Balaton térsége"></button>
  <span class="map-origin map-origin-kiskunhalas" style="left: 49%; top: 67%;" aria-label="Kiskunhalas"></span>
</div>
