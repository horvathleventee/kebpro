    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <h3>Halasi Kebpro Kft.</h3>
          <p><%= t.footer.description %></p>
        </div>
        <div>
          <h4><%= t.footer.legal %></h4>
          <a href="<%= withLang('/adatkezelesi-tajekoztato') %>"><%= t.footer.privacy %></a>
          <a href="<%= withLang('/panaszkezelesi-szabalyzat') %>"><%= t.footer.complaints %></a>
          <a href="<%= withLang('/impresszum') %>"><%= t.footer.imprint %></a>
          <a href="<%= withLang('/belso-visszaeles-bejelentes') %>"><%= t.footer.whistleblowing %></a>
        </div>
        <div>
          <h4><%= t.footer.contact %></h4>
          <p><%= company?.address || '' %></p>
          <% if (company?.phone) { %>
          <a href="tel:<%= company.phone.replace(/\s+/g, '') %>"><%= company.phone %></a>
          <% } %>
          <% if (company?.phone2) { %>
          <a href="tel:<%= company.phone2.replace(/\s+/g, '') %>"><%= company.phone2 %></a>
          <% } %>
          <% if (company?.fax) { %>
          <p>Fax: <%= company.fax %></p>
          <% } %>
          <% if (company?.email) { %>
          <a href="mailto:<%= company.email %>"><%= company.email %></a>
          <% } %>
        </div>
      </div>

      <div class="container footer-bottom">
        <span><%= t.footer.copyright %></span>
      </div>
    </footer>

    <a href="<%= withLang('/palyazatok') %>" class="szechenyi-floating" aria-label="Széchenyi pályázatok">
      <img src="/szechenyi.png" alt="Széchenyi 2020 támogatás" class="szechenyi-floating-logo" />
    </a>

    <!-- Callback widget -->
    <div class="callback-widget" id="callbackWidget">
      <button type="button" class="callback-toggle" id="callbackToggle" aria-label="<%= t.home.callbackBtn %>">
        <svg viewBox="0 0 24 24" fill="none" width="24" height="24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="callback-toggle-text"><%= t.home.callbackBtn %></span>
      </button>
      <div class="callback-panel" id="callbackPanel">
        <h3><%= t.home.callbackTitle %></h3>
        <form method="POST" action="/visszahivas" class="callback-form" id="callbackForm">
          <input type="text" name="name" placeholder="<%= t.home.callbackName %>" required />
          <input type="tel" name="phone" placeholder="<%= t.home.callbackPhone %>" required />
          <select name="timeslot">
            <% t.home.callbackTimes.forEach((slot, i) => { %>
            <option value="<%= slot %>"><%= slot %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn btn-primary"><%= t.home.callbackSend %></button>
        </form>
        <p class="callback-success" id="callbackSuccess"><%= t.home.callbackSuccess %></p>
      </div>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

