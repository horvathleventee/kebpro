    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <h3><%= company.name %></h3>
          <p><%= t.footer.description %></p>
        </div>
        <div>
          <h4><%= t.footer.legal %></h4>
          <a href="<%= withLang('/adatkezelesi-tajekoztato') %>"><%= t.footer.privacy %></a>
          <a href="<%= withLang('/panaszkezelesi-szabalyzat') %>"><%= t.footer.complaints %></a>
          <a href="<%= withLang('/impresszum') %>"><%= t.footer.imprint %></a>
          <a href="<%= withLang('/belso-visszaeles-bejelentes') %>"><%= t.footer.whistleblowing %></a>
        </div>
        <div>
          <h4><%= t.footer.contact %></h4>
          <p><%= company?.address || '' %></p>
          <% if (company?.phone) { %>
          <a href="tel:<%= company.phone.replace(/\s+/g, '') %>"><%= company.phone %></a>
          <% } %>
          <% if (company?.phone2) { %>
          <a href="tel:<%= company.phone2.replace(/\s+/g, '') %>"><%= company.phone2 %></a>
          <% } %>
          <% if (company?.fax) { %>
          <p>Fax: <%= company.fax %></p>
          <% } %>
          <% if (company?.email) { %>
          <a href="mailto:<%= company.email %>"><%= company.email %></a>
          <% } %>
        </div>
      </div>

      <div class="container footer-bottom">
        <span><%= t.footer.copyright %></span>
      </div>
    </footer>

    <a href="<%= withLang('/palyazatok') %>" class="szechenyi-floating" aria-label="Szťchenyi pŠlyŠzatok">
      <img src="/szechenyi.png" alt="Szťchenyi 2020 tŠmogatŠs" class="szechenyi-floating-logo" />
    </a>

    <script src="/js/main.js"></script>
  </body>
</html>
