<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.about.eyebrow %></p>
    <h1><%= t.about.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container grid-2 reveal-grid">
    <article class="panel" data-stagger>
      <h2><%= t.about.introTitle %></h2>
      <% t.about.introText.forEach((paragraph) => { %>
      <p><%= paragraph %></p>
      <% }) %>
    </article>
    <article class="panel" data-stagger>
      <h2><%= t.about.philosophyTitle %></h2>
      <% t.about.philosophyText.forEach((paragraph) => { %>
      <p><%= paragraph %></p>
      <% }) %>
    </article>
  </div>
</section>

<section class="section alt section-animate">
  <div class="container">
    <div class="section-head">
      <h2><%= t.about.logisticsTitle %></h2>
      <p><%= t.about.logisticsLead %></p>
    </div>
    <article class="panel wide">
      <p><%= t.about.logisticsText %></p>
    </article>
  </div>
</section>

<%- include('partials/footer') %>
