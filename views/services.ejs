<%- include('partials/header') %>

<section class="page-hero section-animate">
  <div class="container">
    <p class="eyebrow"><%= t.services.eyebrow %></p>
    <h1><%= t.services.title %></h1>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <article class="panel wide">
      <h2><%= t.services.introTitle %></h2>
      <p><%= t.services.introText %></p>

      <div class="product-category-nav">
        <% categories.forEach((category) => { %>
        <a href="#<%= category.slug %>" class="btn btn-secondary"><%= category.title %></a>
        <% }) %>
      </div>

      <div class="product-card-grid reveal-grid">
        <% categories.forEach((category) => { %>
        <a href="#<%= category.slug %>" class="product-card panel product-card-link" data-stagger>
          <div class="product-image-slot product-image-slot-<%= category.slug %>">
            <img
              src="<%= category.image || `/images/products/${category.slug}.jpg` %>"
              alt="<%= category.title %>"
              class="product-slot-image"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
            />
            <div class="product-placeholder product-placeholder-fallback">
              <span><%= t.services.placeholderLabel %></span>
              <strong><%= category.title %></strong>
            </div>
          </div>
          <h3><%= category.title %></h3>
          <p><%= category.cardLead %></p>
          <span class="text-link"><%= t.services.categoryJump %></span>
        </a>
        <% }) %>
      </div>

      <% categories.forEach((category) => { %>
      <section id="<%= category.slug %>" class="product-category-block">
        <h3><%= category.title %></h3>
        <div class="table-wrap">
          <table class="product-table">
            <thead>
              <tr>
                <th><%= t.services.tableProduct %></th>
                <th><%= t.services.tablePack %></th>
                <th><%= t.services.tableUnit %></th>
                <th><%= t.services.tablePrice %></th>
              </tr>
            </thead>
            <tbody>
              <% category.items.forEach((item) => { %>
              <tr>
                <td><%= item[0] %></td>
                <td><%= item[1] %></td>
                <td><%= item[2] %></td>
                <td><%= t.services.priceCustom %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
      <% }) %>

      <p><%= t.services.customText %></p>
    </article>
  </div>
</section>

<%- include('partials/footer') %>

