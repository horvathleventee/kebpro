  const adapterDescription = diagnostics.adapter === 'postgres' ? a.cloudDb : diagnostics.adapter === 'sqlite' ? a.localDb : a.memoryDb;
  const connectionDescription = diagnostics.initError || (diagnostics.adapter === 'postgres' ? a.pgConfigured : diagnostics.adapter === 'memory' ? a.memoryConfigured : a.sqliteConfigured);
  const currentState = settings.emailEnabled ? a.enabled : a.disabled;
  const currentCareerState = settings.careerEmailEnabled ? a.careerEmailEnabled : a.careerEmailDisabled;
  const storage = diagnostics.storage || {};
%>

<section class="page-hero section-animate">
  <div class="container" style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
    <div>
      <p class="eyebrow"><%= a.eyebrow %></p>
      <h1><%= a.title %></h1>
    </div>
    <a href="/admin/logout" class="btn btn-secondary" style="white-space:nowrap;">Kijelentkezés →</a>
  </div>
</section>

<section class="section section-animate">
  <div class="container admin-overview-grid">
    <div class="panel wide">
      <h2><%= a.emailTitle %></h2>
      <form method="POST" action="/admin/email-settings/update" class="contact-form compact-form">
        <label for="notificationEmail"><%= a.emailLabel %></label>
        <textarea id="notificationEmail" name="notificationEmail" rows="3" required><%= settings.notificationEmail %></textarea>
        <small style="color: var(--muted);"><%= a.emailHint %></small>
        <button type="submit" class="btn btn-secondary"><%= a.saveEmail %></button>
      </form>

      <form method="POST" action="/admin/email-settings/toggle" class="inline-form">
        <span><%= a.state %>: <span class="status-badge <%= settings.emailEnabled ? 'status-active' : 'status-inactive' %>"><%= currentState %></span></span>
        <button type="submit" class="btn btn-primary">
          <%= settings.emailEnabled ? a.disableNotice : a.enableNotice %>
        </button>
      </form>
    </div>

    <div class="panel wide">
      <h2><%= a.careerEmailTitle %></h2>
      <form method="POST" action="/admin/career-email-settings/update" class="contact-form compact-form">
        <label for="careerNotificationEmail"><%= a.careerEmailLabel %></label>
        <textarea id="careerNotificationEmail" name="careerNotificationEmail" rows="3" required><%= settings.careerNotificationEmail || '' %></textarea>
        <small style="color: var(--muted);"><%= a.careerEmailHint %></small>
        <button type="submit" class="btn btn-secondary"><%= a.saveCareerEmail %></button>
      </form>

      <form method="POST" action="/admin/career-email-settings/toggle" class="inline-form">
        <span><%= a.state %>: <span class="status-badge <%= settings.careerEmailEnabled ? 'status-active' : 'status-inactive' %>"><%= currentCareerState %></span></span>
        <button type="submit" class="btn btn-primary">
          <%= settings.careerEmailEnabled ? a.disableCareerNotice : a.enableCareerNotice %>
        </button>
      </form>
    </div>
  </div>
</section>

<section class="section section-animate">
  <div class="container">
    <div class="panel wide">
      <div class="admin-filters">
        <a href="/admin?type=all" class="btn btn-secondary"><%= a.all %></a>
        <a href="/admin?type=quote" class="btn btn-secondary"><%= a.quote %></a>
        <a href="/admin?type=order" class="btn btn-secondary"><%= a.order %></a>
        <a href="/admin?type=callback" class="btn btn-secondary"><%= a.callback %></a>
      </div>

      <% if (!rows || rows.length === 0) { %>
      <p><%= a.empty %></p>
      <% } else { %>
      <div class="table-wrap admin-table-scroll admin-submissions-scroll">
        <table class="admin-table">
          <thead>
            <tr>
              <th><%= a.id %></th>
              <th><%= a.type %></th>
              <th><%= a.status %></th>
              <th><%= a.date %></th>
              <th><%= a.nameCompany %></th>
              <th><%= a.product %></th>
              <th><%= a.quantity %></th>
              <th><%= a.contact %></th>
              <th><%= a.details %></th>
              <th><%= a.actions %></th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((item) => { %>
            <%
              const isCallback = item.type === 'callback' || /visszahív|visszahiv|callback|telefon/i.test(`${item.product || ''} ${item.message || ''}`);
              const rowTypeLabel = item.type === 'order' ? a.order : isCallback ? a.callback : a.quote;
            %>
            <tr>
              <td><%= item.id %></td>
              <td><%= rowTypeLabel %></td>
              <td>
                <form method="POST" action="/admin/igenyek/<%= item.id %>/status?type=<%= selectedType %>" class="status-form">
                  <span class="status-badge status-<%= item.status || 'new' %>">
                    <%= item.status === 'in_progress' ? a.inProgress : item.status === 'closed' ? a.closed : item.status === 'called_back' ? a.calledBack : a.new %>
                  </span>
                  <select name="status" class="status-select">
                    <option value="new" <%= item.status === 'new' ? 'selected' : '' %>><%= a.new %></option>
                    <option value="in_progress" <%= item.status === 'in_progress' ? 'selected' : '' %>><%= a.inProgress %></option>
                    <option value="called_back" <%= item.status === 'called_back' ? 'selected' : '' %>><%= a.calledBack %></option>
                    <option value="closed" <%= item.status === 'closed' ? 'selected' : '' %>><%= a.closed %></option>
                  </select>
                  <button type="submit" class="btn btn-secondary admin-mini-btn"><%= a.save %></button>
                </form>
              </td>
              <td><%= item.created_at %></td>
              <td><strong><%= item.name %></strong><br /><%= item.company %></td>
              <td><%= isCallback ? '-' : item.product %></td>
              <td><%= item.quantity || '-' %></td>
              <td><%= item.email %><br /><%= item.phone %></td>
              <td>
                <% if (item.address) { %><div><%= a.address %>: <%= item.address %></div><% } %>
                <% if (item.company_headquarters) { %><div><%= a.headquarters %>: <%= item.company_headquarters %></div><% } %>
                <% if (item.tax_number) { %><div><%= a.taxNumber %>: <%= item.tax_number %></div><% } %>
                <% if (item.requested_date) { %><div><%= a.requestedDate %>: <%= item.requested_date %></div><% } %>
                <% if (item.message) { %><div><%= a.note %>: <%= item.message %></div><% } %>
              </td>
              <td>
                <form method="POST" action="/admin/igenyek/<%= item.id %>/delete?type=<%= selectedType %>" data-confirm-delete>
                  <button type="submit" class="btn btn-secondary admin-mini-btn admin-danger-btn"><%= a.delete %></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Positions Management -->
<section class="section section-animate">
  <div class="container">
    <div class="panel wide">
      <h2><%= a.positionsTitle %></h2>

      <form method="POST" action="/admin/positions/add" class="contact-form compact-form" style="margin-bottom: 2rem;">
        <h3><%= a.addPosition %></h3>
        <label for="posTitle"><%= a.posTitle %></label>
        <input id="posTitle" name="title" type="text" required />

        <label for="posDesc"><%= a.posDescription %></label>
        <input id="posDesc" name="description" type="text" />

        <label for="posLoc"><%= a.posLocation %></label>
        <input id="posLoc" name="location" type="text" />

        <label for="posType"><%= a.posType %></label>
        <input id="posType" name="type" type="text" />

        <button type="submit" class="btn btn-primary"><%= a.posAdd %></button>
      </form>

      <% if (!positions || positions.length === 0) { %>
      <p><%= a.posEmpty %></p>
      <% } else { %>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th><%= a.id %></th>
              <th><%= a.posTitle %></th>
              <th><%= a.posDescription %></th>
              <th><%= a.posLocation %></th>
              <th><%= a.posType %></th>
              <th><%= a.posActive %></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% positions.forEach((pos) => { %>
            <tr>
              <td><%= pos.id %></td>
              <td><strong><%= pos.title %></strong></td>
              <td><%= pos.description || '-' %></td>
              <td><%= pos.location || '-' %></td>
              <td><%= pos.type || '-' %></td>
              <td><span class="status-badge <%= pos.active ? 'status-active' : 'status-inactive' %>"><%= pos.active ? '✓' : '✗' %></span></td>
              <td>
                <form method="POST" action="/admin/positions/<%= pos.id %>/delete" style="display:inline;" data-confirm-delete>
                  <button type="submit" class="btn btn-secondary admin-mini-btn"><%= a.posDelete %></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Career Applications -->
<section class="section section-animate">
  <div class="container">
    <div class="panel wide">
      <h2><%= a.careerTitle %></h2>

      <% if (!careerApplications || careerApplications.length === 0) { %>
      <p><%= a.careerEmpty %></p>
      <% } else { %>
      <div class="table-wrap admin-table-scroll admin-applications-scroll">
        <table class="admin-table">
          <thead>
            <tr>
              <th><%= a.id %></th>
              <th><%= a.careerDate %></th>
              <th><%= a.careerName %></th>
              <th><%= a.careerEmail %></th>
              <th><%= a.careerPhone %></th>
              <th><%= a.careerPosition %></th>
              <th><%= a.careerMotivation %></th>
              <th><%= a.careerCv %></th>
              <th><%= a.actions %></th>
            </tr>
          </thead>
          <tbody>
            <% careerApplications.forEach((app) => { %>
            <tr>
              <td><%= app.id %></td>
              <td><%= app.created_at %></td>
              <td><strong><%= app.name %></strong></td>
              <td><%= app.email %></td>
              <td><%= app.phone %></td>
              <td><%= app.position_title || '-' %></td>
              <td><%= app.motivation || '-' %></td>
              <td>
                <% if (app.cv_filename) { %>
                <a href="/admin/cv/<%= app.cv_filename %>" target="_blank" class="btn btn-secondary admin-mini-btn"><%= a.downloadCv %></a>
                <% } else { %>-<% } %>
              </td>
              <td>
                <form method="POST" action="/admin/career-applications/<%= app.id %>/delete" data-confirm-delete>
                  <button type="submit" class="btn btn-secondary admin-mini-btn admin-danger-btn"><%= a.delete %></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</section>

<section class="section section-animate admin-db-status-section">
  <div class="container">
    <div class="panel wide admin-db-compact">
      <div class="admin-db-compact-head">
        <div>
          <p class="eyebrow"><%= a.dbTitle %></p>
          <h2><%= diagnostics.adapter %> · <%= diagnostics.initError ? a.statusError : a.statusOk %></h2>
        </div>
        <% if (storage.available !== false) { %>
          <div class="admin-db-compact-meter">
            <strong><%= storage.percent || 0 %>%</strong>
            <span><%= a.storageUsed %>: <%= storage.usedLabel %> / <%= storage.limitLabel %></span>
          </div>
        <% } %>
      </div>

      <div class="admin-db-cards">
        <div class="admin-db-card">
          <span><%= a.adapter %></span>
          <strong><%= diagnostics.adapter %></strong>
          <small><%= adapterDescription %></small>
        </div>
        <div class="admin-db-card">
          <span><%= a.submissions %></span>
          <strong><%= diagnostics.submissionCount %></strong>
          <small><%= diagnostics.lastWriteAt ? `${a.lastWrite}: ${diagnostics.lastWriteAt}` : a.noSaved %></small>
        </div>
        <div class="admin-db-card">
          <span><%= a.connection %></span>
          <strong><%= diagnostics.initError ? a.statusError : a.statusOk %></strong>
          <small><%= connectionDescription %></small>
        </div>
        <div class="admin-db-card admin-storage-card">
          <span><%= a.storageTitle %></span>
          <strong><%= storage.available === false ? a.storageUnavailable : `${storage.percent || 0}%` %></strong>
          <% if (storage.available !== false) { %>
            <div class="admin-storage-bar" aria-hidden="true">
              <span style="width: <%= Math.min(storage.percent || 0, 100) %>%"></span>
            </div>
            <small><%= a.storageFree %>: <%= storage.freeLabel %> · <%= a.storageLimit %>: <%= storage.limitLabel %></small>
          <% } else { %>
            <small><%= storage.note || a.storageUnavailable %></small>
          <% } %>
          <% if (storage.note && storage.available !== false) { %><small><%= storage.note %></small><% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>


